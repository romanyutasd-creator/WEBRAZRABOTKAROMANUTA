                    <button class="cat-btn">Азия</button>
                    <button class="cat-btn">Америка</button>
                    <button class="cat-btn">Африка</button>
                </div>
            </div>
           
            <div class="contacts-photo">
                <img src="https://img.freepik.com/premium-photo/3d-render-world-map_461160-743.jpg?semt=ais_hybrid&w=740&q=80" alt="Путешествие мечты">
            </div>
        </div>
    </div>
</section>

<footer>
    <p>© 2025 TravelWorld. Все права защищены. Путешествуйте с нами!</p>
</footer>

<script>

    document.querySelectorAll('.faq-item').forEach(item => {
        let question = item.querySelector('.faq-question');
        question.addEventListener('click', () => {
            item.classList.toggle('open');
            let text = question.innerHTML;
            if(item.classList.contains('open')) {
                question.innerHTML = text.replace('+', '−');
            } else {
                question.innerHTML = text.replace('−', '+');
            }
        });
    });

 
    document.querySelectorAll('.cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            alert('Специалист подберет для вас лучшие туры в этом направлении!');
        });
    });
</script>
