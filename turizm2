<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TravelWorld - Путешествия</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
        }

        .navbar {
            background: #2c3e50;
            position: sticky;
            top: 0;
            padding: 15px 0;
            z-index: 100;
        }
        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            flex-wrap: wrap;
        }
        .logo {
            color: white;
            font-size: 24px;
            font-weight: bold;
        }
        .nav-links {
            display: flex;
            gap: 25px;
            list-style: none;
        }
        .nav-links a {
            color: white;
            text-decoration: none;
            padding: 5px 0;
            transition: all 0.3s;
        }
        .nav-links a:hover {
            color: #f39c12;
            transform: translateY(-2px);
        }

        section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 60px 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        
        .hero {
            background-image: url('https://gls-space.ams3.digitaloceanspaces.com/lbcms-container-cz_excursions_resale/1f2ffd94-66c1-11eb-bda7-baa2e45fb9df.webp');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: white;
            text-align: center;
            position: relative;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
        }
        .hero .container {
            position: relative;
            z-index: 1;
        }
        .hero h1 {
            font-size: 48px;
            margin-bottom: 20px;
        }
        .hero p {
            font-size: 20px;
            margin-bottom: 30px;
        }

        .btn {
            display: inline-block;
            background: #f39c12;
            color: white;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 30px;
            font-weight: bold;
            transition: all 0.3s;
        }
        .btn:hover {
            background: #e67e22;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            margin-bottom: 40px;
            color: #2c3e50;
        }

        .about-grid {
            display: flex;
            gap: 40px;
            flex-wrap: wrap;
        }
        .about-text {
            flex: 2;
        }
        .about-text h2 {
            color: #2c3e50;
            margin-bottom: 20px;
        }
        .about-text h3 {
            color: #f39c12;
            margin-bottom: 15px;
        }

        .cards-grid {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            width: 300px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .card-img {
            height: 200px;
            overflow: hidden;
        }
        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .card:hover .card-img img {
            transform: scale(1.1);
        }
        .card-content {
            padding: 20px;
        }
        .card-content h3 {
            margin-bottom: 10px;
            color: #2c3e50;
        }
        .price {
            color: #f39c12;
            font-weight: bold;
            font-size: 20px;
            display: inline-block;
            margin: 10px 0;
        }

        .tours-grid {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .tour-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            width: 320px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }
        .tour-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
        .tour-img {
            height: 200px;
            overflow: hidden;
        }
        .tour-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .tour-card:hover .tour-img img {
            transform: scale(1.1);
        }
        .tour-content {
            padding: 20px;
        }
        .tour-content h3 {
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .reviews {
            background: #f5f5f5;
        }
        .reviews-grid {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .review-card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            width: 300px;
            transition: all 0.3s;
        }
        .review-card:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .gallery-grid {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .gallery-item {
            width: 260px;
            height: 200px;
            overflow: hidden;
            border-radius: 10px;
            transition: all 0.3s;
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .gallery-item:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .gallery-item:hover img {
            transform: scale(1.1);
        }

        .faq-list {
            max-width: 800px;
            margin: 0 auto;
        }
        .faq-item {
            background: white;
            margin-bottom: 15px;
            border-radius: 10px;
            border: 1px solid #ddd;
            overflow: hidden;
        }
        .faq-question {
            padding: 15px 20px;
            font-weight: bold;
            cursor: pointer;
            background: #f9f9f9;
            transition: all 0.3s;
        }
        .faq-question:hover {
            background: #f39c12;
            color: white;
            padding-left: 30px;
        }
        .faq-answer {
            padding: 0 20px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }
        .faq-item.open .faq-answer {
            padding: 15px 20px;
            max-height: 200px;
        }

        .contacts-wrapper {
            display: flex;
            gap: 40px;
            flex-wrap: wrap;
        }
        .contacts-info {
            flex: 1;
            background: #f9f9f9;
            padding: 25px;
            border-radius: 15px;
        }
        .contacts-info p {
            margin-bottom: 12px;
        }
        .contacts-photo {
            flex: 1;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }
        .contacts-photo:hover {
            transform: scale(1.02);
        }
        .contacts-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .cat-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
        }
        .cat-btn {
            background: #2c3e50;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .cat-btn:hover {
            background: #f39c12;
            transform: translateY(-2px);
        }

        footer {
            background: #2c3e50;
            color: white;
            text-align: center;
            padding: 20px;
        }

        @media (max-width: 768px) {
            .nav-container {
                flex-direction: column;
                gap: 10px;
            }
            .hero h1 {
                font-size: 32px;
            }
            section {
                min-height: auto;
            }
            .about-grid {
                flex-direction: column;
            }
            .contacts-wrapper {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="nav-container">
        <div class="logo">TravelWorld</div>
        <ul class="nav-links">
            <li><a href="#home">Главная</a></li>
            <li><a href="#about">О нас</a></li>
            <li><a href="#destinations">Направления</a></li>
            <li><a href="#tours">Туры</a></li>
            <li><a href="#reviews">Отзывы</a></li>
