<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>5</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        .task {
            margin-bottom: 20px;
            border: 1px solid #000;
            padding: 10px;
        }
        .code {
            font-family: monospace;
            background: #eee;
            padding: 5px;
            margin: 10px 0;
        }
        .result {
            margin-top: 10px;
            padding: 5px;
        }
        button {
            margin: 5px 0;
        }
        input {
            margin: 5px 0;
        }
    </style>
</head>
<body>

<h1>Лабораторная</h1>

<!--1 -->
<div class="task">
    <h3>Задача 1. Работа с числами</h3>
    
    <div class="code">
        // 1.1 Вернуть число в обратном порядке: 123 -> 321<br>
        // 1.2 Вернуть число без повторяющихся цифр: 111333456 -> 13456<br>
        // 1.3 Сколько раз встречается цифра: (1355567, 5) -> 3<br>
        // 1.4 Самая длинная последовательность 0 или 1 в двоичной записи
    </div>
    
    <p>Введите число: <input type="number" id="task1_num" value="123456"></p>
    <p>Цифра для подсчёта: <input type="number" id="task1_digit" value="5" min="0" max="9"></p>
    <button onclick="task1_all()">Выполнить все подзадачи</button>
    <div class="result" id="result1">Нажмите</div>
</div>

<!--2-->
<div class="task">
    <h3>Задача 2. Работа со строками</h3>
    
    <div class="code">
        // 2.1 Найти первый неповторяющийся символ: 'фывфавыапрс' -> 'п'<br>
        // 2.2 Генерация строки заданной длины из букв и цифр: (5) -> '2fvg6'<br>
        // 2.3 Вернуть только уникальные символы строки: 'позволяеткопироватьтекстиз' -> 'позвляеткираьс'
    </div>
    
    <p>Строка для анализа: <input type="text" id="task2_str" value="фывфавыапрс" style="width: 300px;"></p>
    <p>Длина генерируемой строки: <input type="number" id="task2_len" value="8" min="1" max="50"></p>
    <button onclick="task2_all()">Выполнить все подзадачи</button>
    <div class="result" id="result2">Нажмите</div>
</div>

<script>
    // Вернуть число в обратном порядке: 123 -> 321
    function reverseNumber(num) {
        let str = String(num);
        let reversed = str.split('').reverse().join('');
        return Number(reversed);
    }

    // Вернуть число без повторяющихся цифр: 111333456 -> 13456
    function removeDuplicateDigits(num) {
        let str = String(num);
        let seen = {};
        let result = '';
        
        for (let i = 0; i < str.length; i++) {
            let digit = str[i];
            if (!seen[digit]) {
                seen[digit] = true;
                result += digit;
            }
        }
        
        return Number(result);
    }

    // Посчитать, сколько раз встречается данная цифра: (1355567, 5) -> 3
    //v strok
    function countDigit(num, digit) {
        let str = String(num);
        let count = 0;
        let targetDigit = String(digit);
        
        for (let i = 0; i < str.length; i++) {
            if (str[i] === targetDigit) {
                count++;
            }
        }
        
        return count;
    }

    // Посчитать самую длинную последовательность нулей/единиц в двоичной записи
    function longestBinarySequence(num) {
        let binary = num.toString(2);
        let maxZeros = 0;
        let maxOnes = 0;
        let currentZeros = 0;
        let currentOnes = 0;
        
        for (let i = 0; i < binary.length; i++) {
            if (binary[i] === '0') {
                currentZeros++;
                currentOnes = 0;
                if (currentZeros > maxZeros) maxZeros = currentZeros;
            } else if (binary[i] === '1') {
                currentOnes++;
                currentZeros = 0;
                if (currentOnes > maxOnes) maxOnes = currentOnes;
            }
        }
        
        return {
            binary: binary,
            maxZeros: maxZeros,
            maxOnes: maxOnes,
            maxOverall: Math.max(maxZeros, maxOnes)
        };
    }

    // Найти самый первый неповторяющийся символ в строке
    function firstUniqueChar(str) {
        for (let i = 0; i < str.length; i++) {
            let char = str[i];
            let isUnique = true;
            
            for (let j = 0; j < str.length; j++) {
                if (i !== j && str[j] === char) {
                    isUnique = false;
                    break;
                }
            }
            
            if (isUnique) {
                return char;
            }
        }
        
        return null; // если все символы повторяются
    }

    // Cгенерировать строку заданной длины из случайных символов, взятых из набора английскийх букв и цифр: (5) -> '2fvg6'.
    function generateRandomString(length) {
        let chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
        let result = '';
        
        for (let i = 0; i < length; i++) {
            let randomIndex = Math.floor(Math.random() * chars.length);
            result += chars[randomIndex];
        }
        
        return result;
    }

    // Вернуть только уникальные символы строки: 'позволяеткопироватьтекстиз' -> 'позвляеткираьс'.
    function getUniqueChars(str) {
        let seen = {};
        let result = '';
        
        for (let i = 0; i < str.length; i++) {
            let char = str[i];
            if (!seen[char]) {
                seen[char] = true;
                result += char;
            }
        }
        
        return result;
    }

    //1 зад
    function task1_all() {
        let num = parseInt(document.getElementById("task1_num").value);
        let digit = parseInt(document.getElementById("task1_digit").value);
        
        if (isNaN(num)) {
            alert("Введите корректное число");
            return;
        }
        
        // 1.1
        let reversed = reverseNumber(num);
        
        // 1.2
        let noDuplicates = removeDuplicateDigits(num);
        
        // 1.3
        let digitCount = countDigit(num, digit);
        
        // 1.4
        let binaryInfo = longestBinarySequence(num);
        
        let output = `
            <strong>Исходное число:</strong> ${num}<br>
            <strong>1.1 Число в обратном порядке:</strong> ${reversed}<br>
            <strong>1.2 Число без повторяющихся цифр:</strong> ${noDuplicates}<br>
            <strong>1.3 Цифра ${digit} встречается:</strong> ${digitCount} раз(а)<br>
            <strong>1.4 Двоичная запись:</strong> ${binaryInfo.binary}<br>
            <strong>&nbsp;&nbsp;&nbsp;Самая длинная последовательность нулей:</strong> ${binaryInfo.maxZeros}<br>
            <strong>&nbsp;&nbsp;&nbsp;Самая длинная последовательность единиц:</strong> ${binaryInfo.maxOnes}<br>
            <strong>&nbsp;&nbsp;&nbsp;Максимальная длина последовательности:</strong> ${binaryInfo.maxOverall}
        `;
        
        document.getElementById("result1").innerHTML = output;
        

        console.log("=== Задача 1 ===");
        console.log("Число:", num);
        console.log("Обратный порядок:", reversed);
        console.log("Без повторяющихся цифр:", noDuplicates);
        console.log("Количество цифр", digit + ":", digitCount);
        console.log("Двоичная запись:", binaryInfo.binary);
        console.log("Макс. последовательность нулей:", binaryInfo.maxZeros);
        console.log("Макс. последовательность единиц:", binaryInfo.maxOnes);
    }

    // зад2
    function task2_all() {
        let inputStr = document.getElementById("task2_str").value;
        let length = parseInt(document.getElementById("task2_len").value);
        
        if (isNaN(length) || length < 1) {
            alert("Введите корректную длину (≥ 1)");
            return;
        }
        
        // 2.1
        let firstUnique = firstUniqueChar(inputStr);
        
        // 2.2
        let randomString = generateRandomString(length);
        
        // 2.3
        let uniqueChars = getUniqueChars(inputStr);
        
        let output = `
            <strong>Исходная строка:</strong> "${inputStr}"<br>
            <strong>2.1 Первый неповторяющийся символ:</strong> ${firstUnique === null ? "не найден" : "'" + firstUnique + "'"}<br>
            <strong>2.2 Строка из ${length} случайных символов:</strong> ${randomString}<br>
            <strong>2.3 Уникальные символы строки:</strong> ${uniqueChars}
        `;
        
        document.getElementById("result2").innerHTML = output;
        
        console.log("=== Задача 2 ===");
        console.log("Исходная строка:", inputStr);
        console.log("Первый неповторяющийся символ:", firstUnique);
        console.log("Случайная строка (длина " + length + "):", randomString);
        console.log("Уникальные символы:", uniqueChars);
    }
</script>

</body>
</html>
