<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Список дел</title>


<style>
:root {
--green: #2f4f4f;
--light: #f5f5f5;
--gray: #e0e0e0;
--text-gray: #9e9e9e;
--red: #e53935;
}

* {
margin: 0;
padding: 0;
box-sizing: border-box;
}

body {
font-family: 'Roboto', sans-serif;
height: 100vh;
background: radial-gradient(circle, #3e6b6b, var(--green));
}

.app {
height: 100%;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
}

.title {
color: white;
font-size: 42px;
margin-bottom: 30px;
font-weight: 500;
}

.controls {
display: flex;
width: 700px;
max-width: 90%;
}

.controls input {
flex: 1;
padding: 15px;
border: none;
background: #eee;
font-size: 16px;
}

.controls button {
border: none;
padding: 15px 25px;
font-size: 16px;
cursor: pointer;
}

.add {
background: #e0e0e0;
}

.clear {
background: var(--red);
color: black;
}

@media (max-width: 700px) {
.controls {
flex-direction: column;
}
}

.list {
margin-top: 40px;
width: 700px;
max-width: 90%;
}

.item {
display: flex;
justify-content: space-between;
align-items: center;
background: var(--light);
padding: 15px 20px;
border-bottom: 1px solid #ccc;
transition: 0.2s;
}

.item:hover {
background: #eaeaea;
}

.item.done {
background: #dcdcdc;
color: #777;
}

.item.done .item-text {
text-decoration: line-through;
}

.left {
display: flex;
align-items: center;
gap: 15px;
}

.check {
font-size: 20px;
color: #ccc;
}

.item.done .check {
color: #4caf50;
}

.item-text {
max-width: 400px;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}

.date {
font-size: 12px;
color: var(--text-gray);
margin-top: 3px;
}

.delete {
font-size: 20px;
color: #aaa;
cursor: pointer;
}

.delete:hover {
color: black;
}

.empty {
position: absolute;
top: 50%;
transform: translateY(-50%);
color: white;
font-size: 22px;
}

.list:not(:empty) + .empty {
display: none;
}

footer {
position: fixed;
bottom: 0;
width: 100%;
text-align: center;
color: #ccc;
padding: 10px;
}
</style>
</head>

<body>

<div class="app">

<div class="title">Список дел</div>

<div class="controls">
<input type="text" placeholder="Новый элемент списка">
<button class="add">Создать</button>
<button class="clear">Очистить всё</button>
</div>

<div class="list">

<div class="item done">
<div class="left">
<div class="check">✔</div>
<div>
<div class="item-text">Почесать кошку</div>
<div class="date">от 14.08.2023</div>
</div>
</div>
<div class="delete">✕</div>
</div>

<div class="item">
<div class="left">
<div class="check"></div>
<div>
<div class="item-text">Полить картошку</div>
<div class="date">от 04.05.2022</div>
</div>
</div>
<div class="delete">✕</div>
</div>

<div class="item">
<div class="left">
<div class="check"></div>
<div>
<div class="item-text">Сложить в лукошко</div>
<div class="date">от 19.05.2022</div>
</div>
</div>
<div class="delete">✕</div>
</div>

</div>

<div class="empty">Не найдено ни одного дела</div>

<footer>Copyright ©</footer>

</div>

</body>
</html>
